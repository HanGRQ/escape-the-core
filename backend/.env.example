# Anthropic — used for Doctor K AI responses and all AI logic.
# No OpenAI key needed — embeddings run locally via sentence-transformers.
ANTHROPIC_API_KEY=sk-ant-...

# Firebase — paste values from your Firebase project settings > Service accounts
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
